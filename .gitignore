cat > .gitignore <<'EOF'
# Dependencies
node_modules/

# Next.js
.next/
out-next/
.vercel/

# Build outputs
dist/
build/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / Editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Foundry
cache/
out/
broadcast/
coverage/
lcov.info

# Solidity / artifacts
artifacts/
typechain/
typechain-types/

# Database local files / dumps
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
*.backup

# Temporary files
tmp/
temp/
*.tmp

# Local generated scripts/output
.env.production
.env.local
.env.development.local
.env.test.local
.env.production.local

# PM2 / process files
pm2*.json
ecosystem.local.config.js

# Misc secrets
*.pem
*.key
*.cert
*.p12
*.keystore
EOF